{{ 'section-header.css' | asset_url | stylesheet_tag }}

<header
  class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}{% if section.settings.transparent_header %} site-header--transparent{% endif %}"
  id="SiteHeader"
  role="banner"
>
  <div class="site-header__inner">

    {%- comment -%} Desktop Navigation Left {%- endcomment -%}
    <nav class="site-header__nav site-header__nav--desktop" aria-label="{{ 'accessibility.nav_primary' | t }}">
      {%- if section.settings.menu != blank -%}
        {%- for link in linklists[section.settings.menu].links -%}
          <a
            href="{{ link.url }}"
            class="site-header__nav-link{% if link.active %} site-header__nav-link--active{% endif %}"
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    {%- comment -%} Logo Center {%- endcomment -%}
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag:
            loading: 'eager',
            width: section.settings.logo_width,
            alt: shop.name,
            class: 'site-header__logo-image'
          }}
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Icons Right {%- endcomment -%}
    <div class="site-header__icons">
      {%- if section.settings.show_search -%}
        <button
          type="button"
          class="site-header__icon-btn"
          aria-label="{{ 'general.search.search' | t }}"
          id="SearchToggle"
        >
          {%- render 'icon-search' -%}
        </button>
      {%- endif -%}

      {%- if section.settings.show_account -%}
        <a
          href="{{ routes.account_url }}"
          class="site-header__icon-btn"
          aria-label="{{ 'customer.account.title' | t }}"
        >
          {%- render 'icon-account' -%}
        </a>
      {%- endif -%}

      <button
        type="button"
        class="site-header__icon-btn site-header__cart-btn"
        aria-label="{{ 'sections.cart.title' | t }}"
        id="CartToggle"
        data-cart-toggle
      >
        {%- render 'icon-cart' -%}
        <span class="site-header__cart-count" id="CartCount" aria-live="polite">
          {{ cart.item_count }}
        </span>
      </button>

      {%- comment -%} Mobile Hamburger {%- endcomment -%}
      <button
        type="button"
        class="site-header__icon-btn site-header__hamburger"
        aria-label="{{ 'general.accessibility.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="MobileMenu"
        id="HamburgerBtn"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>

  </div>

  {%- comment -%} Search Bar {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div class="site-header__search" id="SearchBar" aria-hidden="true" role="search">
      <div class="site-header__search-inner">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input
            type="search"
            name="q"
            placeholder="{{ 'general.search.placeholder' | t }}"
            aria-label="{{ 'general.search.search' | t }}"
            class="site-header__search-input"
          >
          <button type="submit" aria-label="{{ 'general.search.search' | t }}" class="site-header__search-submit">
            {%- render 'icon-search' -%}
          </button>
        </form>
        <button type="button" class="site-header__search-close" aria-label="{{ 'general.accessibility.close' | t }}" id="SearchClose">
          &times;
        </button>
      </div>
    </div>
  {%- endif -%}

</header>

{%- comment -%} Mobile Menu Overlay {%- endcomment -%}
<div class="mobile-menu" id="MobileMenu" aria-hidden="true" role="dialog" aria-label="{{ 'general.accessibility.nav_primary' | t }}">
  <div class="mobile-menu__header">
    <div class="mobile-menu__logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 160 | image_tag:
          loading: 'eager',
          width: 160,
          alt: shop.name
        }}
      {%- else -%}
        <span class="mobile-menu__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </div>
    <button
      type="button"
      class="mobile-menu__close"
      aria-label="{{ 'general.accessibility.close_menu' | t }}"
      id="MobileMenuClose"
    >
      &times;
    </button>
  </div>

  <nav class="mobile-menu__nav" aria-label="{{ 'accessibility.nav_primary' | t }}">
    {%- if section.settings.menu != blank -%}
      {%- for link in linklists[section.settings.menu].links -%}
        <a
          href="{{ link.url }}"
          class="mobile-menu__nav-link{% if link.active %} mobile-menu__nav-link--active{% endif %}"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    {%- endif -%}
  </nav>

  <div class="mobile-menu__footer">
    {%- if settings.social_instagram != blank -%}
      <a href="{{ settings.social_instagram }}" class="mobile-menu__social-link" aria-label="Instagram" target="_blank" rel="noopener">
        Instagram
      </a>
    {%- endif -%}
    {%- if settings.social_tiktok != blank -%}
      <a href="{{ settings.social_tiktok }}" class="mobile-menu__social-link" aria-label="TikTok" target="_blank" rel="noopener">
        TikTok
      </a>
    {%- endif -%}
  </div>
</div>

<div class="mobile-menu-overlay" id="MobileMenuOverlay"></div>

<script>
(function() {
  const header = document.getElementById('SiteHeader');
  const hamburger = document.getElementById('HamburgerBtn');
  const mobileMenu = document.getElementById('MobileMenu');
  const mobileMenuClose = document.getElementById('MobileMenuClose');
  const mobileMenuOverlay = document.getElementById('MobileMenuOverlay');
  const searchToggle = document.getElementById('SearchToggle');
  const searchBar = document.getElementById('SearchBar');
  const searchClose = document.getElementById('SearchClose');

  // Sticky / transparent header on scroll
  {%- if section.settings.sticky_header or section.settings.transparent_header -%}
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (!entry.isIntersecting) {
        header.classList.add('site-header--scrolled');
      } else {
        header.classList.remove('site-header--scrolled');
      }
    },
    { rootMargin: '-80px 0px 0px 0px' }
  );
  const hero = document.querySelector('.hero-banner, .section-hero');
  if (hero) observer.observe(hero);
  {%- endif -%}

  // Mobile menu toggle
  function openMobileMenu() {
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileMenu.classList.add('is-open');
    mobileMenuOverlay.classList.add('is-visible');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.classList.add('menu-open');
    // Focus trap
    mobileMenuClose.focus();
  }

  function closeMobileMenu() {
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenu.classList.remove('is-open');
    mobileMenuOverlay.classList.remove('is-visible');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('menu-open');
    hamburger.focus();
  }

  if (hamburger) hamburger.addEventListener('click', openMobileMenu);
  if (mobileMenuClose) mobileMenuClose.addEventListener('click', closeMobileMenu);
  if (mobileMenuOverlay) mobileMenuOverlay.addEventListener('click', closeMobileMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (mobileMenu.classList.contains('is-open')) closeMobileMenu();
      if (searchBar && !searchBar.getAttribute('aria-hidden') === false) closeSearch();
    }
  });

  // Search toggle
  if (searchToggle && searchBar) {
    function openSearch() {
      searchBar.setAttribute('aria-hidden', 'false');
      searchBar.classList.add('is-open');
      searchBar.querySelector('input').focus();
    }
    function closeSearch() {
      searchBar.setAttribute('aria-hidden', 'true');
      searchBar.classList.remove('is-open');
    }
    searchToggle.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
  }
})();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 180,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "default": true,
      "label": "Show search icon"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "default": true,
      "label": "Show account icon"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "default": true,
      "label": "Enable sticky header"
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "default": true,
      "label": "Transparent header on homepage"
    }
  ]
}
{% endschema %}
