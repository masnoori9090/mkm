{{ 'section-bestsellers.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
-%}

<section class="bestsellers" id="Bestsellers-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="bestsellers__heading reveal-on-scroll">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="bestsellers__carousel-wrap">
    {%- if section.settings.show_arrows -%}
      <button
        type="button"
        class="bestsellers__arrow bestsellers__arrow--prev"
        aria-label="{{ 'sections.carousel.prev' | t }}"
        data-carousel-prev
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
    {%- endif -%}

    <div
      class="bestsellers__carousel"
      id="BestsellersCarousel-{{ section.id }}"
      data-autoplay="{{ section.settings.enable_autoplay }}"
      data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
    >
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          <div class="bestsellers__item">
            {%- render 'product-card', product: product, show_add_to_bag: true -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="bestsellers__item">
            <div class="product-card product-card--placeholder">
              <div class="product-card__image-wrap">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'product-card__placeholder-svg' }}
              </div>
              <div class="product-card__info">
                <p class="product-card__vendor">Get Any Scent</p>
                <p class="product-card__title">Sample Fragrance {{ forloop.index }}</p>
                <p class="product-card__price">AED 450</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_arrows -%}
      <button
        type="button"
        class="bestsellers__arrow bestsellers__arrow--next"
        aria-label="{{ 'sections.carousel.next' | t }}"
        data-carousel-next
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  const section = document.getElementById('Bestsellers-{{ section.id }}');
  if (!section) return;

  const carousel = section.querySelector('[data-carousel-prev]') ? section : null;
  const track = document.getElementById('BestsellersCarousel-{{ section.id }}');
  const prevBtn = section.querySelector('[data-carousel-prev]');
  const nextBtn = section.querySelector('[data-carousel-next]');

  if (!track) return;

  const autoplay = track.dataset.autoplay === 'true';
  const autoplaySpeed = parseInt(track.dataset.autoplaySpeed) || 5000;

  function getCardWidth() {
    const firstCard = track.querySelector('.bestsellers__item');
    if (!firstCard) return 0;
    const style = window.getComputedStyle(firstCard);
    return firstCard.offsetWidth + parseInt(style.marginRight || 0);
  }

  function scrollPrev() {
    track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
  }

  function scrollNext() {
    track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
  }

  if (prevBtn) prevBtn.addEventListener('click', scrollPrev);
  if (nextBtn) nextBtn.addEventListener('click', scrollNext);

  if (autoplay) {
    let interval = setInterval(scrollNext, autoplaySpeed);
    track.addEventListener('mouseenter', () => clearInterval(interval));
    track.addEventListener('mouseleave', () => {
      interval = setInterval(scrollNext, autoplaySpeed);
    });
  }
})();
</script>

{% schema %}
{
  "name": "Bestsellers Carousel",
  "class": "section-bestsellers-carousel",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BESTSELLERS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "Show navigation arrows"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "Enable autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s",
      "label": "Autoplay speed"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Carousel"
    }
  ]
}
{% endschema %}
