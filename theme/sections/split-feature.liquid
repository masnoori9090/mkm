{{ 'section-split-feature.css' | asset_url | stylesheet_tag }}

<section
  class="split-feature split-feature--image-{{ section.settings.image_position }}"
  id="SplitFeature-{{ section.id }}"
  style="--content-bg: {{ section.settings.content_bg_color }}; --text-color: {{ section.settings.text_color }};"
>
  <div class="split-feature__grid">

    <div class="split-feature__image-col">
      {%- if section.settings.image != blank -%}
        <div class="split-feature__image-wrap">
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            width: 900,
            class: 'split-feature__image',
            sizes: '(min-width: 1024px) 50vw, 100vw'
          }}
        </div>
      {%- else -%}
        <div class="split-feature__image-wrap split-feature__image-wrap--placeholder">
          {{ 'collection-1' | placeholder_svg_tag: 'split-feature__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="split-feature__content-col">
      <div class="split-feature__content">
        {%- if section.settings.subtitle != blank -%}
          <p class="split-feature__subtitle reveal-on-scroll">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="split-feature__heading reveal-on-scroll">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <div class="split-feature__body rte reveal-on-scroll">{{ section.settings.body_text }}</div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_item' -%}
            <div class="split-feature__feature-item reveal-on-scroll" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <span class="split-feature__feature-icon">{{ block.settings.icon }}</span>
              {%- endif -%}
              <div>
                {%- if block.settings.title != blank -%}
                  <strong class="split-feature__feature-title">{{ block.settings.title }}</strong>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="split-feature__feature-text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.button_label != blank -%}
          <div class="split-feature__cta reveal-on-scroll">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="btn btn--outline"
            >
              {{ section.settings.button_label }}
              {%- render 'icon-arrow' -%}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Split Feature",
  "class": "section-split-feature",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle (gold script)",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE HOUSE OF GET ANY SCENT"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Born in Dubai's vibrant fragrance culture, Get Any Scent curates the world's most exclusive niche perfumes.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Discover Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content background color",
      "default": "#132616"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F2ED"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or symbol)",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Authentic Fragrances"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "100% genuine, sourced directly from master perfumers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split Feature",
      "settings": {
        "subtitle": "Our Story",
        "heading": "THE HOUSE OF GET ANY SCENT",
        "button_label": "Discover Our Story"
      }
    }
  ]
}
{% endschema %}
