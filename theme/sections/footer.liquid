{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__main">
    <div class="container">
      <div class="site-footer__grid">

        {%- comment -%} Column 1: Brand {%- endcomment -%}
        <div class="site-footer__col site-footer__col--brand">
          {%- if section.settings.logo != blank -%}
            <a href="{{ routes.root_url }}" class="site-footer__logo-link" aria-label="{{ shop.name }}">
              {{ section.settings.logo | image_url: width: 180 | image_tag:
                loading: 'lazy',
                width: 180,
                alt: shop.name,
                class: 'site-footer__logo'
              }}
            </a>
          {%- else -%}
            <a href="{{ routes.root_url }}" class="site-footer__logo-text">{{ shop.name }}</a>
          {%- endif -%}

          {%- if section.settings.brand_description != blank -%}
            <div class="site-footer__brand-desc rte">{{ section.settings.brand_description }}</div>
          {%- endif -%}

          <div class="site-footer__social">
            {%- if settings.social_instagram != blank -%}
              <a href="{{ settings.social_instagram }}" class="site-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_tiktok != blank -%}
              <a href="{{ settings.social_tiktok }}" class="site-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34v-7a8.16 8.16 0 0 0 4.77 1.52V6.4a4.85 4.85 0 0 1-1-.29z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a href="{{ settings.social_facebook }}" class="site-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Column 2: Quick Links {%- endcomment -%}
        <div class="site-footer__col">
          <h3 class="site-footer__col-heading">{{ 'sections.footer.quick_links' | t }}</h3>
          {%- if section.settings.quick_links != blank -%}
            <ul class="site-footer__nav-list">
              {%- for link in linklists[section.settings.quick_links].links -%}
                <li>
                  <a href="{{ link.url }}" class="site-footer__nav-link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- comment -%} Column 3: Help {%- endcomment -%}
        <div class="site-footer__col">
          <h3 class="site-footer__col-heading">{{ 'sections.footer.help' | t }}</h3>
          {%- if section.settings.help_menu != blank -%}
            <ul class="site-footer__nav-list">
              {%- for link in linklists[section.settings.help_menu].links -%}
                <li>
                  <a href="{{ link.url }}" class="site-footer__nav-link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- comment -%} Column 4: Contact {%- endcomment -%}
        <div class="site-footer__col">
          <h3 class="site-footer__col-heading">{{ 'sections.footer.contact' | t }}</h3>
          <div class="site-footer__contact">
            {%- if section.settings.contact_email != blank -%}
              <p class="site-footer__contact-item">
                <a href="mailto:{{ section.settings.contact_email }}" class="site-footer__contact-link">
                  {{ section.settings.contact_email }}
                </a>
              </p>
            {%- endif -%}
            {%- if section.settings.contact_phone != blank -%}
              <p class="site-footer__contact-item">
                <a href="tel:{{ section.settings.contact_phone }}" class="site-footer__contact-link">
                  {{ section.settings.contact_phone }}
                </a>
              </p>
            {%- endif -%}
            {%- if section.settings.location != blank -%}
              <p class="site-footer__contact-item site-footer__location">
                {{ section.settings.location }}
              </p>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container">
      <div class="site-footer__bottom-inner">
        <div class="site-footer__copyright rte">
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text }}
          {%- else -%}
            <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.meta.all_rights_reserved' | t }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.show_payment_icons -%}
          <div class="site-footer__payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "richtext",
      "id": "brand_description",
      "label": "Brand description",
      "default": "<p>Dubai's premier destination for niche and luxury fragrances. Curated for the discerning nose.</p>"
    },
    {
      "type": "link_list",
      "id": "quick_links",
      "default": "footer",
      "label": "Quick links menu"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "default": "footer",
      "label": "Help menu"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "hello@getanyscent.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact phone"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Dubai, UAE"
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "Copyright text"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "default": true,
      "label": "Show payment icons"
    }
  ]
}
{% endschema %}
