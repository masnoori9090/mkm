{%- comment -%}
  Renders a responsive image with srcset.
  Usage: {% render 'responsive-image', image: image, widths: '400,800,1200,1600', sizes: '100vw', class: 'my-class', loading: 'lazy', alt: 'Alt text' %}
{%- endcomment -%}

{%- liquid
  assign widths = widths | default: '400,800,1200'
  assign loading = loading | default: 'lazy'
  assign alt = alt | default: image.alt | default: ''
  assign widths_array = widths | split: ','
-%}

{%- if image != blank -%}
  <img
    src="{{ image | image_url: width: 800 }}"
    srcset="{%- for width in widths_array -%}
      {{ image | image_url: width: width }} {{ width }}w{% unless forloop.last %}, {% endunless %}
    {%- endfor -%}"
    sizes="{{ sizes | default: '100vw' }}"
    alt="{{ alt | escape }}"
    loading="{{ loading }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    {% if class %}class="{{ class }}"{% endif %}
  >
{%- endif -%}
