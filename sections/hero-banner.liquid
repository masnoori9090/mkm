{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign layout = section.settings.layout | default: 'image_left'
  assign text_align = section.settings.text_alignment | default: 'left'
  assign overlay_opacity = section.settings.overlay_opacity | default: 40
  assign overlay_decimal = overlay_opacity | divided_by: 100.0
-%}

<section
  class="hero-banner hero-banner--{{ layout }} hero-banner--text-{{ text_align }}{% if section.settings.enable_parallax %} hero-banner--parallax{% endif %}"
  id="HeroBanner-{{ section.id }}"
  data-section-id="{{ section.id }}"
>

  {%- if layout == 'full_overlay' -%}
    {%- comment -%} Full-width overlay layout {%- endcomment -%}
    <div class="hero-banner__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1920 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          width: 1920,
          height: 1080,
          class: 'hero-banner__image',
          data-parallax-target: '',
          sizes: '100vw'
        }}
      {%- else -%}
        <div class="hero-banner__image hero-banner__image--placeholder"></div>
      {%- endif -%}
      <div class="hero-banner__overlay" style="opacity: {{ overlay_decimal }};"></div>
    </div>
    <div class="hero-banner__content hero-banner__content--overlay">
      {%- render 'hero-banner-content', section: section -%}
    </div>

  {%- else -%}
    {%- comment -%} Split layout: image left or image right {%- endcomment -%}
    <div class="hero-banner__split">
      <div class="hero-banner__media hero-banner__media--split">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            width: 1200,
            class: 'hero-banner__image',
            data-parallax-target: '',
            sizes: '(min-width: 1024px) 60vw, 100vw'
          }}
        {%- else -%}
          <div class="hero-banner__image hero-banner__image--placeholder"></div>
        {%- endif -%}
      </div>
      <div class="hero-banner__content hero-banner__content--split">
        {%- render 'hero-banner-content', section: section -%}
      </div>
    </div>
  {%- endif -%}

  <div class="hero-banner__scroll-indicator" aria-hidden="true">
    <span class="hero-banner__scroll-line"></span>
  </div>

</section>

{%- if section.settings.enable_parallax -%}
<script>
(function() {
  const section = document.getElementById('HeroBanner-{{ section.id }}');
  const img = section ? section.querySelector('[data-parallax-target]') : null;
  if (!img || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  function applyParallax() {
    const scrollY = window.pageYOffset;
    const rect = section.getBoundingClientRect();
    const sectionTop = rect.top + scrollY;
    const offset = (scrollY - sectionTop) * 0.3;
    img.style.transform = 'translateY(' + offset + 'px) scale(1.1)';
  }

  window.addEventListener('scroll', applyParallax, { passive: true });
  applyParallax();
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hero Banner",
  "class": "section-hero-banner",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE ART OF SCENT"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover our curated collection of niche fragrances, artisan-crafted for the discerning nose.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        { "value": "image_left", "label": "Image left / Text right" },
        { "value": "image_right", "label": "Image right / Text left" },
        { "value": "full_overlay", "label": "Full-width overlay" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%",
      "label": "Overlay opacity (full-width mode)"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "default": true,
      "label": "Enable parallax effect on image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "heading": "THE ART OF SCENT",
        "subtitle": "New Collection",
        "button_label": "Explore Now"
      }
    }
  ]
}
{% endschema %}
