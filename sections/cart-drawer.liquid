{{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}

<div
  class="cart-drawer"
  id="CartDrawer"
  aria-label="{{ 'sections.cart.title' | t }}"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
>
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">{{ 'sections.cart.title' | t }}</h2>
    <button
      type="button"
      class="cart-drawer__close"
      aria-label="{{ 'general.accessibility.close' | t }}"
      id="CartDrawerClose"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  {%- comment -%} Free shipping progress bar {%- endcomment -%}
  {%- assign threshold = settings.free_shipping_threshold | times: 100 -%}
  {%- if threshold > 0 -%}
    <div class="cart-drawer__shipping-bar" id="CartShippingBar">
      <div class="cart-drawer__shipping-bar-inner">
        <p class="cart-drawer__shipping-text" id="CartShippingText">
          {%- if cart.total_price >= threshold -%}
            {{ 'sections.cart.free_shipping_reached' | t }}
          {%- else -%}
            {%- assign remaining = threshold | minus: cart.total_price | money -%}
            {{ 'sections.cart.free_shipping_progress' | t: remaining: remaining }}
          {%- endif -%}
        </p>
        <div class="cart-drawer__shipping-progress">
          {%- assign progress = cart.total_price | times: 100 | divided_by: threshold | at_most: 100 -%}
          <div class="cart-drawer__shipping-fill" id="CartShippingFill" style="width: {{ progress }}%;"></div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="cart-drawer__body" id="CartDrawerBody">
    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        <p class="cart-drawer__empty-text">{{ 'sections.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline cart-drawer__continue">
          {{ 'sections.cart.continue_shopping' | t }}
        </a>
      </div>
    {%- else -%}
      <ul class="cart-drawer__items" id="CartItems" role="list" aria-label="{{ 'sections.cart.items' | t }}">
        {%- for item in cart.items -%}
          <li class="cart-drawer__item" data-line="{{ forloop.index }}">
            <div class="cart-drawer__item-image-wrap">
              {%- if item.image != blank -%}
                {{ item.image | image_url: width: 120 | image_tag:
                  loading: 'lazy',
                  width: 120,
                  height: 120,
                  class: 'cart-drawer__item-image',
                  alt: item.title
                }}
              {%- endif -%}
            </div>
            <div class="cart-drawer__item-info">
              <p class="cart-drawer__item-vendor">{{ item.vendor }}</p>
              <h3 class="cart-drawer__item-title">
                <a href="{{ item.url }}">{{ item.product_title }}</a>
              </h3>
              {%- if item.variant.title != 'Default Title' -%}
                <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
              {%- endif -%}
              <div class="cart-drawer__item-bottom">
                <div class="cart-drawer__quantity">
                  <button
                    type="button"
                    class="cart-drawer__qty-btn"
                    aria-label="{{ 'sections.cart.decrease_quantity' | t }}"
                    data-change="-1"
                    data-line="{{ forloop.index }}"
                  >−</button>
                  <span class="cart-drawer__qty-value">{{ item.quantity }}</span>
                  <button
                    type="button"
                    class="cart-drawer__qty-btn"
                    aria-label="{{ 'sections.cart.increase_quantity' | t }}"
                    data-change="1"
                    data-line="{{ forloop.index }}"
                  >+</button>
                </div>
                <p class="cart-drawer__item-price">{{ item.final_line_price | money }}</p>
                <button
                  type="button"
                  class="cart-drawer__item-remove"
                  aria-label="{{ 'sections.cart.remove' | t: title: item.title }}"
                  data-line="{{ forloop.index }}"
                  data-remove
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  <div class="cart-drawer__footer" id="CartFooter">
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">{{ 'sections.cart.subtotal' | t }}</span>
        <span class="cart-drawer__subtotal-price" id="CartSubtotal">{{ cart.total_price | money }}</span>
      </div>
      <a href="{{ routes.checkout }}" class="btn btn--solid cart-drawer__checkout">
        {{ 'sections.cart.checkout' | t }}
      </a>
      <button type="button" class="cart-drawer__continue-link" id="CartContinueShopping">
        {{ 'sections.cart.continue_shopping' | t }}
      </button>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "class": "section-cart-drawer"
}
{% endschema %}
