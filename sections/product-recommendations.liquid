{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<section class="product-recommendations" id="ProductRecommendations-{{ section.id }}" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">

  {%- if recommendations.performed? and recommendations.products_count > 0 -%}
    <div class="container">
      {%- if section.settings.heading != blank -%}
        <h2 class="featured-collection__heading reveal-on-scroll">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="featured-collection__grid featured-collection__grid--equal">
        {%- for product in recommendations.products -%}
          <div class="featured-collection__card-wrap reveal-on-scroll">
            {%- render 'product-card', product: product -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  const section = document.getElementById('ProductRecommendations-{{ section.id }}');
  if (!section || !section.dataset.url) return;

  fetch(section.dataset.url)
    .then(r => r.text())
    .then(text => {
      const html = document.createElement('div');
      html.innerHTML = text;
      const newSection = html.querySelector('#ProductRecommendations-{{ section.id }}');
      if (newSection) {
        section.innerHTML = newSection.innerHTML;
        // Re-init scroll reveal
        document.dispatchEvent(new Event('scroll-reveal:init'));
      }
    })
    .catch(() => {});
})();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "class": "section-product-recommendations",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOU MAY ALSO LIKE"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ]
}
{% endschema %}
